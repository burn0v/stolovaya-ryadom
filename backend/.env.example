# База (по умолчанию PostgreSQL; для SQLite: USE_SQLITE=1)
# POSTGRES_DB=canteennear
# POSTGRES_USER=canteennear
# POSTGRES_PASSWORD=canteennear
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432

# Почта для сброса пароля (по умолчанию — читаемый вывод в консоль runserver)
# EMAIL_BACKEND=canteennear.email.ReadableConsoleEmailBackend
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# EMAIL_USE_TLS=true
# DEFAULT_FROM_EMAIL=noreply@example.com

# ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com
